# Frontend Environment Variables
# Copy to .env.local and customize

# API base URL — set this when running the frontend on a different machine (e.g., Vercel)
# Leave empty when running on the same machine as the backend
# Example: VITE_API_BASE=http://192.168.1.100:8000
VITE_API_BASE=

# WebSocket base URL — set this for remote monitoring
# Example: VITE_WS_BASE=ws://192.168.1.100:8000
VITE_WS_BASE=
